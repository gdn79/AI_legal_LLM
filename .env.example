APP_ENV=local

POSTGRES_DB=legal_ai
POSTGRES_USER=legal_ai
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://legal_ai:change-me@postgres:5432/legal_ai
SEED_PASSWORD=ChangeMe123!

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=legal_rag
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

BACKEND_PORT=8000
FRONTEND_PORT=3000
LLM_PORT=8010
NEXT_PUBLIC_API_URL=http://localhost:8000/api

JWT_SECRET=change-me-super-secret
REQUEST_ID_HEADER=X-Request-Id

LLM_BASE_URL=http://llm-server:8010
LLM_API_KEY=stub-key
LLM_MODEL=stub-openai-compatible
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512
EMBEDDING_MODEL=stub-embedding

RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150

FNS_PROVIDER_MODE=MOCK_FOR_DEV
RUSSIAN_POST_MODE=MOCK_FOR_DEV
RUSSIAN_POST_API_BASE_URL=https://dev-null.local/russian-post
RUSSIAN_POST_TIMEOUT_SECONDS=30
COURT_PROVIDER_MODE=MOCK_FOR_DEV
COURT_ARBITR_BASE_URL=https://dev-null.local/court-arbitr
COURT_ARBITR_TIMEOUT_SECONDS=30

WORKER_SLEEP_SECONDS=30
